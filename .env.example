# Copy to ".env" in the repo root (same folder as harness.yaml).
# HarnessLab loads this when you run manage.py, evaluator_cli.py, or other tools that call env_bootstrap.
# Existing shell/CI variables take precedence over this file.
#
# Secrets only — which model each role uses is configured in harness.yaml under `models:`.

# --- Anthropic (default Brain: evaluator / contract_verifier when provider is anthropic or Claude CLI) ---
ANTHROPIC_API_KEY=

# --- OpenAI (harness.yaml: evaluator_provider / contract_verifier_provider: openai) ---
OPENAI_API_KEY=

# --- DeepSeek (harness.yaml: provider openai-compatible + base_url https://api.deepseek.com) ---
# Used before OPENAI_API_KEY for that endpoint so you can keep both OpenAI and DeepSeek keys.
DEEPSEEK_API_KEY=

# --- Other OpenAI-compatible APIs (Groq, local Ollama /v1, proxies, …) ---
# Used when base_url is not DeepSeek; falls back to OPENAI_API_KEY if unset.
OPENAI_COMPATIBLE_API_KEY=
