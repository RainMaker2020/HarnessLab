# Copy to ".env" in the repo root (same folder as harness.yaml).
# HarnessLab loads this automatically when you run core/main.py.
# Existing shell/CI variables take precedence over this file.

# Brain: Anthropic Messages API (default evaluator / contract_verifier provider)
ANTHROPIC_API_KEY=

# Brain: OpenAI Chat Completions or OpenAI-compatible servers (DeepSeek, Groq, Ollama, etc.)
OPENAI_API_KEY=
